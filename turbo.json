{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "SUPABASE_SECRET_KEY",
    "SESSION_SECRET",
    "STOREFRONT_BASE_URL",
    "ADMIN_BASE_URL",
    "AI_AGENT_ENABLED",
    "AI_AGENT_USERNAME",
    "AI_AGENT_DISPLAY_NAME",
    "AI_AGENT_MODEL",
    "AI_AGENT_MAX_CONTEXT_MESSAGES",
    "AI_AGENT_SAFE_MODE",
    "AI_AGENT_TEMPERATURE",
    "AI_AGENT_MAX_TOKENS",
    "AI_AGENT_TIMEOUT_MS",
    "AI_AGENT_MAX_TURNS",
    "OPENAI_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "cache": false
    },
    "test:run": {
      "dependsOn": ["^build"]
    },
    "format": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
