{
  "name": "auth_shop_platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.11.0",
  "scripts": {
    "typecheck": "turbo typecheck",
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset": "npx tsx scripts/reset-db.ts",
    "db:seed:e2e": "npx tsx scripts/seed-e2e.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:security": "vitest run tests/security/",
    "test:unit": "vitest run tests/unit/",
    "test:components": "vitest run tests/components/",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "check:cycles": "madge --circular --extensions ts,tsx apps",
    "format": "biome format --write ./apps ./packages ./tests",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "biome check --write --unsafe"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
