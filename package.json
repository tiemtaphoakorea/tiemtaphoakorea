    "drizzle-orm": "^0.45.1",
    "isbot": "^5.1.31",
    "jose": "^6.1.3",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.562.0",
    "next": "^16.1.5",
    "postcss": "^8.5.6",
    "postgres": "^3.4.7",
    "radix-ui": "^1.4.3",
